{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/videos/*", "/robots.txt", "/sitemap.xml", "/*.{css,js,ico,png,jpg,jpeg,gif,svg,webp,woff,woff2,ttf,otf,mp4,webm,mov,mp3,xml,txt}"]
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "globalHeaders": {
    "cache-control": "no-cache"
  },
  "routes": [
    {
      "route": "/assets/*",
      "headers": { "cache-control": "public, max-age=31536000, immutable" }
    }
  ]
}
